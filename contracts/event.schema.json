{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rumor-checking.local/contracts/event.schema.json",
  "title": "Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "summary",
    "source_url",
    "source_name",
    "published_at",
    "keywords",
    "mode"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "source_name": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "mode": {
      "type": "string",
      "enum": [
        "complete_mode",
        "partial_mode",
        "safe_mode"
      ]
    }
  }
}
