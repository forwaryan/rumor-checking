APP_NAME=rumor-checking-backend
APP_ENV=development
APP_VERSION=0.1.0
APP_LOG_LEVEL=INFO
APP_DEBUG=false
API_V1_PREFIX=/api/v1

# Real provider switch: off | kimi
ANALYSIS_PROVIDER=off

# Lightweight investigation agent: when enabled AND ANALYSIS_PROVIDER=kimi with a key,
# the pipeline may run up to AGENT_MAX_EXTRA_ROUNDS extra evidence-driven retrieval rounds.
# On the default off+mock baseline this stays inert and behavior is unchanged.
LIGHTWEIGHT_AGENT_ENABLED=false
AGENT_MAX_EXTRA_ROUNDS=1

# Agent orchestrator: routes analysis through the pluggable agent loop
# (backend/app/agent) instead of the fixed pipeline. The default RulePlanner
# reproduces the legacy pipeline exactly (proven by test_agent_orchestrator),
# so on off+mock the output is identical; it falls back to the fixed pipeline
# on any runner error.
AGENT_ORCHESTRATOR_ENABLED=false

# Max times the LLM planner may fetch a full evidence page body (fetch_url tool)
# to strengthen grounding. Only fires on the agent + Kimi path; 0 disables it.
# Each fetch is a live HTTP round, so keep this small.
AGENT_MAX_URL_FETCHES=1

# Paste your real Kimi key into backend/.env, not into this example file.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
# Model used for agent reasoning/planning/synthesis (config decides it verbatim).
# Pick a model your key can actually access — verify against GET /v1/models.
KIMI_SEARCH_MODEL=moonshot-v1-8k
PROVIDER_TIMEOUT_SECONDS=20

# Retrieval switch: mock | gdelt | agent | kimi | off
# For real Kimi web retrieval (RETRIEVAL_PROVIDER=kimi), the $web_search tool
# loop feeds web-page content back into the model, so an 8k-context model
# overflows (HTTP 400 token limit). Use a larger-context model for retrieval,
# e.g. KIMI_SEARCH_MODEL=moonshot-v1-32k, and raise RETRIEVAL_TIMEOUT_SECONDS
# to >=45 (the default 12s times out on the tool loop).
RETRIEVAL_PROVIDER=mock
RETRIEVAL_TIMEOUT_SECONDS=12
RETRIEVAL_GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
RETRIEVAL_MAX_RESULTS=8
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL_SECONDS=43200
RETRIEVAL_CACHE_ALLOW_STALE_ON_ERROR=true
RETRIEVAL_FALLBACK_TO_MOCK=true
# RETRIEVAL_CACHE_DIR=/abs/path/to/data/cache/retrieval
URL_FETCH_CACHE_ENABLED=true
URL_FETCH_CACHE_TTL_SECONDS=43200
# URL_FETCH_CACHE_DIR=/abs/path/to/data/cache/url_fetch
