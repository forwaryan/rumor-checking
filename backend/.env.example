APP_NAME=rumor-checking-backend
APP_ENV=development
APP_VERSION=0.1.0
APP_LOG_LEVEL=INFO
APP_DEBUG=false
API_V1_PREFIX=/api/v1

# Real provider switch: off | kimi
ANALYSIS_PROVIDER=off

# Lightweight investigation agent: when enabled AND ANALYSIS_PROVIDER=kimi with a key,
# the pipeline may run up to AGENT_MAX_EXTRA_ROUNDS extra evidence-driven retrieval rounds.
# On the default off+mock baseline this stays inert and behavior is unchanged.
LIGHTWEIGHT_AGENT_ENABLED=false
AGENT_MAX_EXTRA_ROUNDS=1

# Agent orchestrator: routes analysis through the pluggable agent loop
# (backend/app/agent) instead of the fixed pipeline. The default RulePlanner
# reproduces the legacy pipeline exactly (proven by test_agent_orchestrator),
# so on off+mock the output is identical; it falls back to the fixed pipeline
# on any runner error.
AGENT_ORCHESTRATOR_ENABLED=false

# Max times the LLM planner may fetch a full evidence page body (fetch_url tool)
# to strengthen grounding. Only fires on the agent + LLM path; 0 disables it.
# Each fetch is a live HTTP round, so keep this small.
AGENT_MAX_URL_FETCHES=1

# Paste your real LLM key and endpoint into backend/.env (gitignored), NOT here.
# Any OpenAI-compatible chat/completions gateway works; the call layer streams
# (stream=true) so streaming-only models are fine. Leave these blank in the example.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
# Optional per-model base-URL overrides (model=url,model2=url2) for models served
# on a different gateway path than LLM_BASE_URL. Unlisted models use LLM_BASE_URL.
# e.g. LLM_MODEL_BASE_URLS=some-model=https://gateway.example/v2
LLM_MODEL_BASE_URLS=
LLM_MODEL=
# Optional comma-separated whitelist of models the frontend picker may choose
# from (deep mode). The request's chosen model is validated against this list;
# anything not listed falls back to LLM_MODEL. Leave empty to offer only LLM_MODEL.
# e.g. LLM_MODELS=model-a,model-b
LLM_MODELS=
# Model used for agent reasoning/planning/synthesis (config decides it verbatim).
# Pick a model your key/gateway can actually access.
LLM_SEARCH_MODEL=
LLM_TEMPERATURE=0.1
# Output-token cap for fast (non-reasoning) models. Also backs a client-side
# runaway guard: the stream is cut once content exceeds this by a wide margin,
# so a model that ignores max_tokens can't flood for minutes.
LLM_MAX_TOKENS=4096
# Reasoning models emit a long chain-of-thought before the answer, so they need a
# bigger token budget and a much longer timeout, and must NOT be pinned to a JSON
# response_format (it makes some stall with zero output). List the model names
# that are reasoning models here (comma-separated); they then use the two knobs
# below instead of LLM_MAX_TOKENS / PROVIDER_TIMEOUT_SECONDS. Leave blank if all
# your models answer immediately.
LLM_REASONING_MODELS=
LLM_REASONING_MAX_TOKENS=16000
LLM_REASONING_TIMEOUT_SECONDS=200
# Reasoning models can intermittently stall with empty output (chain-of-thought
# never terminates). An empty completion is retried this many times before giving
# up and falling back. Only applies to reasoning models; fast models get one shot.
LLM_REASONING_RETRIES=2
# Synthesis is the single heaviest LLM call (largest JSON body, preceded by a long
# chain-of-thought on reasoning models). This multiplies the reasoning timeout for
# JUST that call so its body completes without extending every short planner call.
LLM_SYNTHESIS_TIMEOUT_MULTIPLIER=1.5
# LLM-driven search-query extraction. Off by default: it costs a full LLM
# round-trip per analysis, and the rule-based query builder already produces
# clean deduplicated queries. Turn on only if you want entity/alias extraction
# and can absorb the extra latency; synthesis still uses the LLM regardless.
LLM_QUERY_EXTRACTION_ENABLED=false
PROVIDER_TIMEOUT_SECONDS=45

# Retrieval switch: mock | gdelt | playwright | kimi | off
# - mock: deterministic fixture data (default for dev/demo)
# - gdelt: free GDELT news API (English-biased, weak Chinese coverage)
# - playwright: web scraping search (Baidu first, Bing fallback; good Chinese coverage)
#   No extra dependencies needed — uses httpx to fetch search engine HTML.
# - kimi: LLM builtin $web_search (only works with providers that support it)
RETRIEVAL_PROVIDER=mock
RETRIEVAL_TIMEOUT_SECONDS=12
RETRIEVAL_GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
RETRIEVAL_MAX_RESULTS=8
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL_SECONDS=43200
RETRIEVAL_CACHE_ALLOW_STALE_ON_ERROR=true
RETRIEVAL_FALLBACK_TO_MOCK=true
# RETRIEVAL_CACHE_DIR=/abs/path/to/data/cache/retrieval
URL_FETCH_CACHE_ENABLED=true
URL_FETCH_CACHE_TTL_SECONDS=43200
# URL_FETCH_CACHE_DIR=/abs/path/to/data/cache/url_fetch

